{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    // ✅ FIX PATH ALIAS
    "baseUrl": ".",
    "paths": {
      "@/": [
        "./"
      ]
    },
    // ✅ TS6 WARNING FIX
    "ignoreDeprecations": "6.0",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "*/.ts",
    "*/.tsx",
    ".next/types/*/.ts",
    ".next/dev/types/*/.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}